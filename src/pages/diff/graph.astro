---
import Layout from '../../components/Layout.astro';
import { getDiffData } from '../../lib/getDiffData';

const { counts, error: diffError } = await getDiffData(Astro.url);

let graphData: { nodes: any[]; edges: any[]; fetchedAt?: number } = { nodes: [], edges: [] };
let graphError: string | null = null;

try {
  const res = await fetch(new URL('/api/graph', Astro.url));
  const json = await res.json();
  if (json.error) {
    graphError = json.error;
  } else {
    graphData = json;
  }
} catch (err) {
  graphError = err instanceof Error ? err.message : String(err);
}

const nodeCount = graphData.nodes?.length ?? 0;
const edgeCount = graphData.edges?.length ?? 0;
const m2oCount = graphData.edges?.filter((e: any) => e.data?.type === 'm2o').length ?? 0;
const m2mCount = graphData.edges?.filter((e: any) => e.data?.type === 'm2m').length ?? 0;
const m2aCount = graphData.edges?.filter((e: any) => e.data?.type === 'm2a').length ?? 0;
const junctionCount = graphData.nodes?.filter((n: any) => n.data?.isJunction).length ?? 0;
const fetchedAtStr = graphData.fetchedAt ? new Date(graphData.fetchedAt).toLocaleString() : 'unknown';
---

<Layout title="Relationship Graph" active="/diff/graph" counts={counts}>
  <div class="banner">
    <div>
      <h1>🕸️ Relationship Graph</h1>
      <div class="meta">
        {nodeCount} collections ({junctionCount} junction) · {m2oCount} M2O · {m2mCount} M2M · {m2aCount} M2A · fetched {fetchedAtStr}
      </div>
    </div>
    <button class="btn" id="refresh-btn">↻ Refresh</button>
  </div>

  {graphError && <div class="error-banner">⚠️ {graphError}</div>}
  {diffError && <div class="error-banner">⚠️ (sidebar counts) {diffError}</div>}

  <!-- Toolbar -->
  <div class="graph-toolbar">
    <div class="toolbar-group">
      <button class="btn view-btn active" id="view-graph">⬡ Graph</button>
      <button class="btn view-btn" id="view-table">⊞ Table</button>
    </div>
    <div class="toolbar-sep"></div>

    <div id="graph-only-controls">
      <div class="toolbar-group">
        <span class="toolbar-label">Layout</span>
        <select id="layout-select" class="toolbar-select">
          <option value="cose">Force Directed</option>
          <option value="breadthfirst">Hierarchy</option>
          <option value="concentric">Concentric</option>
          <option value="circle">Circle</option>
          <option value="grid">Grid</option>
        </select>
      </div>

      <div class="toolbar-group">
        <span class="toolbar-label">Show</span>
        <label class="toolbar-check"><input type="checkbox" id="show-m2o" checked> <span class="edge-dot m2o-dot"></span>M2O</label>
        <label class="toolbar-check"><input type="checkbox" id="show-m2m" checked> <span class="edge-dot m2m-dot"></span>M2M</label>
        <label class="toolbar-check"><input type="checkbox" id="show-m2a" checked> <span class="edge-dot m2a-dot"></span>M2A</label>
        <label class="toolbar-check"><input type="checkbox" id="show-junctions" checked> <span class="edge-dot junc-dot"></span>Junctions</label>
      </div>

      <div class="toolbar-group">
        <button class="btn" id="fit-btn" title="Fit all">⊡ Fit</button>
        <button class="btn" id="zoom-in-btn" title="Zoom in">+</button>
        <button class="btn" id="zoom-out-btn" title="Zoom out">−</button>
      </div>
    </div>

    <div class="toolbar-group" style="margin-left:auto;">
      <input type="search" id="node-search" class="section-search-input" style="max-width:200px;" placeholder="Search collections…" autocomplete="off" />
    </div>
  </div>

  <!-- Graph + info panel -->
  <div class="graph-layout" id="graph-layout">
    <div id="cy" class="cy-container"></div>
    <div id="info-panel" class="info-panel" style="display:none;">
      <div class="info-placeholder">Click a node to see details</div>
    </div>
  </div>

  <!-- Table view -->
  <div id="table-view" style="display:none;">
    <div class="rel-table-wrap">
      <table class="rel-table">
        <thead>
          <tr>
            <th>Collection</th>
            <th>M2O &rarr;</th>
            <th>&larr; O2M</th>
            <th>&#8596; M2M</th>
            <th>M2A</th>
            <th class="col-count" title="Total connections">#</th>
          </tr>
        </thead>
        <tbody id="rel-tbody"></tbody>
      </table>
    </div>
    <div id="table-empty" class="table-empty" style="display:none;">No collections match.</div>
  </div>

  <!-- Legend -->
  <div class="graph-legend">
    <span class="legend-title">Legend</span>
    <span class="legend-item">
      <span class="legend-node" style="border-color:#6366f1;"></span>Collection
    </span>
    <span class="legend-item">
      <span class="legend-node" style="border-color:#f59e0b;width:14px;height:14px;"></span>Junction table
    </span>
    <span class="legend-sep"></span>
    <span class="legend-item">
      <span class="legend-line" style="background:#94a3b8;"></span>M2O (many-to-one)
    </span>
    <span class="legend-item">
      <span class="legend-line" style="background:#6366f1;border-top:2px dashed #6366f1;background:none;display:inline-block;width:28px;height:2px;border-bottom:none;"></span>M2M (many-to-many)
    </span>
    <span class="legend-item">
      <span class="legend-line" style="background:#22c55e;border-top:2px dotted #22c55e;background:none;display:inline-block;width:28px;height:2px;border-bottom:none;"></span>M2A (many-to-any)
    </span>
  </div>
</Layout>

<style>
/* Override max-width for the graph page */
:global(.main) {
  max-width: none !important;
}

.graph-toolbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 8px 16px;
  padding: 10px 14px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  margin-bottom: 16px;
}

.toolbar-group {
  display: flex;
  align-items: center;
  gap: 8px;
}

.toolbar-label {
  font-size: 11px;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  color: var(--color-muted);
  white-space: nowrap;
}

.toolbar-select {
  padding: 5px 8px;
  border-radius: var(--radius);
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
  font-size: 13px;
  cursor: pointer;
}

.toolbar-check {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 13px;
  color: var(--color-text);
  cursor: pointer;
  white-space: nowrap;
}

.edge-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: 50%;
}
.m2o-dot { background: #94a3b8; }
.m2m-dot { background: #6366f1; }
.m2a-dot { background: #22c55e; }
.junc-dot { background: #f59e0b; }

.graph-layout {
  display: flex;
  gap: 14px;
  align-items: flex-start;
  margin-bottom: 16px;
}

.cy-container {
  flex: 1;
  height: 680px;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  background: #080a10;
  min-width: 0;
}

.info-panel {
  width: 300px;
  flex-shrink: 0;
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  background: var(--color-surface);
  padding: 16px;
  max-height: 680px;
  overflow-y: auto;
  font-size: 13px;
}

.info-placeholder {
  color: var(--color-muted);
  font-style: italic;
  text-align: center;
  padding: 40px 0;
}

.info-header {
  font-size: 14px;
  font-weight: 600;
  margin-bottom: 4px;
  word-break: break-all;
}

.info-degree {
  font-size: 12px;
  color: var(--color-muted);
  margin-bottom: 14px;
}

.info-section-label {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  margin-bottom: 6px;
  margin-top: 12px;
}

.info-conn {
  display: flex;
  flex-direction: column;
  gap: 2px;
  padding: 6px 8px;
  background: rgba(255,255,255,0.04);
  border-radius: 4px;
  margin-bottom: 4px;
}

.info-conn-main {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
}

.info-conn-via {
  font-size: 10px;
  color: var(--color-muted);
  padding-left: 2px;
}

.graph-legend {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 6px 16px;
  padding: 10px 14px;
  background: var(--color-surface);
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  font-size: 12px;
  color: var(--color-muted);
}

.legend-title {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.8px;
  color: var(--color-muted);
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 6px;
  color: var(--color-text);
}

.legend-sep {
  width: 1px;
  height: 16px;
  background: var(--color-border);
}

.legend-node {
  display: inline-block;
  width: 18px;
  height: 18px;
  border-radius: 4px;
  background: #1a1d27;
  border: 2px solid;
  flex-shrink: 0;
}

.legend-line {
  display: inline-block;
  width: 28px;
  height: 2px;
  flex-shrink: 0;
}

/* ── View toggle ─────────────────────────────────────────────────────────── */
.toolbar-sep {
  width: 1px;
  height: 22px;
  background: var(--color-border);
  flex-shrink: 0;
}

#graph-only-controls {
  display: contents; /* transparent flex wrapper — children are direct flex items */
}

.view-btn {
  font-size: 12px;
  padding: 4px 10px;
  border-radius: var(--radius);
  background: transparent;
  border: 1px solid var(--color-border);
  color: var(--color-muted);
  cursor: pointer;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}

.view-btn:hover {
  border-color: var(--color-accent);
  color: var(--color-text);
}

.view-btn.active {
  background: var(--color-accent);
  border-color: var(--color-accent);
  color: #fff;
}

/* ── Relationship table ──────────────────────────────────────────────────── */
.rel-table-wrap {
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  overflow: auto;
  margin-bottom: 12px;
}

.rel-table {
  width: 100%;
  border-collapse: collapse;
  font-size: 12px;
  font-family: 'JetBrains Mono', 'Fira Code', monospace;
}

.rel-table th {
  position: sticky;
  top: 0;
  background: var(--color-surface);
  padding: 8px 12px;
  text-align: left;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.7px;
  color: var(--color-muted);
  border-bottom: 1px solid var(--color-border);
  white-space: nowrap;
  z-index: 1;
}

.rel-table th.col-count {
  text-align: center;
  width: 40px;
}

.rel-table td {
  padding: 7px 12px;
  vertical-align: top;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.rel-table td.col-count {
  text-align: center;
  color: var(--color-muted);
  font-size: 11px;
}

.rel-row {
  cursor: pointer;
  transition: background 0.1s;
}

.rel-row:hover {
