---
import Layout from '../../components/Layout.astro';
import { getDiffData } from '../../lib/getDiffData';
import type { ContentDiffData, ContentMatchedCollection } from '../api/content-diff';

const { counts } = await getDiffData(Astro.url);

const res = await fetch(new URL('/api/content-diff', Astro.url));
const data: ContentDiffData & { error?: string } = await res.json();

const matched: ContentMatchedCollection[] = data.matched ?? [];

const totalCollections    = matched.length;
const totalItemsWithDiffs = matched.reduce((s, c) => s + c.changedCount, 0);
const totalDevOnly        = matched.reduce((s, c) => s + c.devOnlyCount, 0);
const totalProdOnly       = matched.reduce((s, c) => s + c.prodOnlyCount, 0);
const totalInSync         = matched.reduce((s, c) => s + c.inSyncCount, 0);

const totalDiffs = totalItemsWithDiffs + totalDevOnly + totalProdOnly;
const contentDiffs = totalDiffs;

const fetchedAt = data.fetchedAt ? new Date(data.fetchedAt).toLocaleString() : 'unknown';
---
<Layout title="Content Parity" active="/content" counts={{ ...counts, contentDiffs }}>
  <div class="banner">
    <div>
      <h1>Content Parity</h1>
      <div class="meta">Compare and sync content between dev and prod · Last fetched: {fetchedAt}</div>
    </div>
    <button class="btn" id="refresh-btn">↻ Refresh</button>
  </div>

  {data.error && (
    <div class="error-banner">⚠️ {data.error}</div>
  )}
  {data.devSnapshotError && (
    <div class="error-banner">⚠️ Dev snapshot error: {data.devSnapshotError}</div>
  )}
  {data.prodSnapshotError && (
    <div class="error-banner">⚠️ Prod snapshot error: {data.prodSnapshotError}</div>
  )}

  <!-- Stat cards -->
  <div class="summary-grid">
    <div class="stat-card">
      <div class="num">{totalCollections}</div>
      <div class="label">Collections</div>
    </div>
    <div class="stat-card" style={totalItemsWithDiffs > 0 ? 'border-color: var(--color-warning)' : ''}>
      <div class="num" style={totalItemsWithDiffs > 0 ? 'color: var(--color-warning)' : ''}>{totalItemsWithDiffs}</div>
      <div class="label">Changed Items</div>
    </div>
    <div class="stat-card" style={totalDevOnly > 0 ? 'border-color: var(--color-create)' : ''}>
      <div class="num" style={totalDevOnly > 0 ? 'color: var(--color-create)' : ''}>{totalDevOnly}</div>
      <div class="label">Dev Only</div>
    </div>
    <div class="stat-card" style={totalProdOnly > 0 ? 'border-color: var(--color-delete)' : ''}>
      <div class="num" style={totalProdOnly > 0 ? 'color: var(--color-delete)' : ''}>{totalProdOnly}</div>
      <div class="label">Prod Only</div>
    </div>
    <div class="stat-card">
      <div class="num" style="color: var(--color-muted)">{totalInSync}</div>
      <div class="label">In Sync</div>
    </div>
  </div>

  <!-- Orphan banners -->
  {data.devOnlyCollections && data.devOnlyCollections.length > 0 && (
    <div class="orphan-banner orphan-dev">
      <strong>Collections only in dev:</strong>{' '}
      {data.devOnlyCollections.join(', ')}
    </div>
  )}
  {data.prodOnlyCollections && data.prodOnlyCollections.length > 0 && (
    <div class="orphan-banner orphan-prod">
      <strong>Collections only in prod:</strong>{' '}
      {data.prodOnlyCollections.join(', ')}
    </div>
  )}

  <!-- Collections table -->
  {matched.length === 0 ? (
    <div class="empty">No page collections found.</div>
  ) : (
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Collection</th>
            <th style="width: 140px; text-align: center;">DEV / PROD</th>
            <th style="width: 100px; text-align: center;">Changed</th>
            <th style="width: 90px; text-align: center;">Dev Only</th>
            <th style="width: 90px; text-align: center;">Prod Only</th>
            <th style="width: 80px; text-align: center;">In Sync</th>
            <th style="width: 60px;"></th>
          </tr>
        </thead>
        <tbody>
          {matched.map((coll) => (
            <tr class={coll.hasDiffs ? 'row-has-diffs' : ''}>
              <td>
                <a href={`/content/${coll.collection}`} class="coll-link">
                  {coll.label}
                </a>
                <div style="margin-top: 2px;">
                  <code class="mono muted">{coll.collection}</code>
                </div>
                {coll.devError && (
                  <div class="coll-error">⚠️ dev: {coll.devError}</div>
                )}
                {coll.prodError && (
                  <div class="coll-error">⚠️ prod: {coll.prodError}</div>
                )}
              </td>
              <td style="text-align: center;">
                <span class="env-count env-count-dev">{coll.devTotal}</span>
                <span style="color: var(--color-muted); margin: 0 3px;">/</span>
                <span class="env-count env-count-prod">{coll.prodTotal}</span>
              </td>
              <td style="text-align: center;">
                {coll.changedCount > 0
                  ? <span class="env-badge env-badge-changed">{coll.changedCount}</span>
                  : <span class="muted">—</span>
                }
              </td>
              <td style="text-align: center;">
                {coll.devOnlyCount > 0
                  ? <span class="env-badge env-badge-dev">{coll.devOnlyCount}</span>
                  : <span class="muted">—</span>
                }
              </td>
              <td style="text-align: center;">
                {coll.prodOnlyCount > 0
                  ? <span class="env-badge env-badge-prod">{coll.prodOnlyCount}</span>
                  : <span class="muted">—</span>
                }
              </td>
              <td style="text-align: center;">
                {coll.inSyncCount > 0
                  ? <span class="in-sync-count">{coll.inSyncCount}</span>
                  : <span class="muted">—</span>
                }
              </td>
              <td style="text-align: center;">
                <a href={`/content/${coll.collection}`} class="view-link">View →</a>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  )}
</Layout>

<style>
.meta { color: var(--color-muted); font-size: 12px; margin-top: 4px; }

.orphan-banner {
  padding: 10px 14px;
  border-radius: var(--radius);
  font-size: 13px;
  margin-bottom: 16px;
}
.orphan-dev  { background: rgba(16,185,129,0.08);  border: 1px solid rgba(16,185,129,0.25); color: var(--color-create); }
.orphan-prod { background: rgba(248,113,113,0.08); border: 1px solid rgba(248,113,113,0.25); color: var(--color-delete); }

.coll-link {
  font-weight: 600;
  font-size: 14px;
  color: var(--color-text);
  text-decoration: none;
}
.coll-link:hover { color: var(--color-accent); text-decoration: underline; }

.coll-error {
  font-size: 11px;
  color: var(--color-error);
  margin-top: 2px;
}

.row-has-diffs td { background: rgba(251,191,36,0.02); }
.row-has-diffs:hover td { background: rgba(251,191,36,0.04); }

.env-count {
  font-size: 11px;
  font-weight: 600;
  padding: 2px 8px;
  border-radius: 10px;
}
.env-count-dev  { background: rgba(16,185,129,0.12);  color: var(--color-create); border: 1px solid rgba(16,185,129,0.25); }
.env-count-prod { background: rgba(99,102,241,0.12);   color: #a5b4fc;             border: 1px solid rgba(99,102,241,0.25); }

.env-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 8px;
}
.env-badge-dev     { background: rgba(16,185,129,0.15);  color: var(--color-create); border: 1px solid rgba(16,185,129,0.3); }
.env-badge-prod    { background: rgba(248,113,113,0.15); color: var(--color-delete); border: 1px solid rgba(248,113,113,0.3); }
.env-badge-changed { background: rgba(251,191,36,0.15);  color: var(--color-warning); border: 1px solid rgba(251,191,36,0.3); }

.in-sync-count {
  font-size: 12px;
  color: var(--color-muted);
}

.view-link {
  font-size: 12px;
  color: var(--color-accent);
  text-decoration: none;
  white-space: nowrap;
}
.view-link:hover { text-decoration: underline; }
</style>

<script>
document.getElementById('refresh-btn')?.addEventListener('click', async () => {
  const btn = document.getElementById('refresh-btn') as HTMLButtonElement;
  btn.textContent = '↻ Refreshing…';
  btn.disabled = true;
  await fetch('/api/content-diff?refresh=true');
  location.reload();
});
</script>
